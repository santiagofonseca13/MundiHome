<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado de Módulos (RBAC)"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Desactiva funciones para todos los usuarios en tiempo real."
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw_inicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Módulo Inicio / Feed"
                    android:padding="10dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw_chats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Módulo de Chats"
                    android:padding="10dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw_publicar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Módulo Publicar Anuncio"
                    android:padding="10dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw_anuncios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Módulo Mis Anuncios"
                    android:padding="10dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw_cuenta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Módulo de Cuenta / Perfil"
                    android:padding="10dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw_ubicacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ubicación Geográfica (GPS/Mapas)"
                    android:padding="10dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>